# OpenAI API
OPENAI_API_KEY=sk-...

# Models (updated automatically after fine-tuning)
CODER_MODEL=gpt-4o-mini
REVIEWER_MODEL=gpt-4o-mini
# Judge is always GPT-4o — cross-family to reduce evaluation bias
JUDGE_MODEL=gpt-4o

# Repo
REPO_PATH=/tmp/sympy
GITHUB_TOKEN=ghp_...

# Loop config
MAX_ROUNDS=4
REWARD_UNCERTAINTY_THRESHOLD=0.25
MIN_POSITIVE_EXAMPLES_FOR_FINETUNE=5

# Lean4 (optional — install from https://leanprover.github.io/lean4/doc/setup.html)
LEAN_BINARY=/usr/local/bin/lean
